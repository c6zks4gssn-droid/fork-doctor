name: CI
on:
  push:
    branches: [main]
  pull_request:
    branches: [main]
jobs:
  lint:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
{% if language == "python" %}
      - uses: actions/setup-python@v5
        with:
          python-version: '3.12'
      - run: pip install ruff
      - run: ruff check .
  test:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: '3.12'
      - run: pip install -e . || pip install -r requirements.txt || true
      - run: python -m pytest || true
{% elif language in ("javascript", "typescript") %}
      - uses: actions/setup-node@v4
        with:
          node-version: '20'
      - run: npm ci || yarn install --frozen-lockfile || true
      - run: npm run lint || npx eslint . || true
  test:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: '20'
      - run: npm ci || yarn install --frozen-lockfile || true
      - run: npm test || true
{% elif language == "go" %}
      - uses: actions/setup-go@v5
        with:
          go-version: '1.22'
      - run: go vet ./...
      - run: golint ./... || true
  test:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-go@v5
        with:
          go-version: '1.22'
      - run: go test ./...
{% elif language == "rust" %}
      - uses: dtolnay/rust-toolchain@stable
      - run: cargo clippy -- -D warnings
  test:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: dtolnay/rust-toolchain@stable
      - run: cargo test
{% else %}
      - run: echo "Add project-specific lint steps"
  test:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - run: echo "Add project-specific test steps"
{% endif %}
  build:
    runs-on: ubuntu-latest
    needs: [lint, test]
    steps:
      - uses: actions/checkout@v4
{% if language == "python" %}
      - run: pip install build && python -m build
{% elif language in ("javascript", "typescript") %}
      - run: npm run build || true
{% elif language == "go" %}
      - run: go build ./...
{% elif language == "rust" %}
      - run: cargo build --release
{% else %}
      - run: echo "Add project-specific build steps"
{% endif %}
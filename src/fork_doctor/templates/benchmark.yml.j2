name: Benchmark
on:
  pull_request:
    branches: [main]
jobs:
  bench:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
{% if language == "python" %}
      - uses: actions/setup-python@v5
        with:
          python-version: '3.12'
      - run: pip install pytest-benchmark
      - run: python -m pytest --benchmark-only --benchmark-json=bench.json || true
{% elif language in ("javascript", "typescript") %}
      - uses: actions/setup-node@v4
        with:
          node-version: '20'
      - run: npm ci
      - run: npm run benchmark || true
{% elif language == "go" %}
      - uses: actions/setup-go@v5
        with:
          go-version: '1.22'
      - run: go test -bench=. -benchmem ./...
{% elif language == "rust" %}
      - uses: dtolnay/rust-toolchain@stable
      - run: cargo bench
{% else %}
      - run: echo "Add project-specific benchmark commands"
{% endif %}
      - uses: actions/upload-artifact@v4
        with:
          name: benchmark-results
          path: bench.json